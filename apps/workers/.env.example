# MongoDB connection string (must match apps/web)
MONGO_URL=mongodb://localhost:27017/secondseat

# Directory where uploaded files are stored — must match INGEST_UPLOAD_DIR in apps/web
# In containerised deployments both apps must mount the same volume at this path
INGEST_UPLOAD_DIR=/tmp/secondseat-uploads

# Max retry attempts for the delete-source BullMQ job (default 3)
DELETE_QUEUE_ATTEMPTS=3

# Redis connection string (for BullMQ)
REDIS_URL=redis://localhost:6379

# BullMQ queue name (must match INGEST_QUEUE_NAME in apps/web/.env)
INGEST_QUEUE_NAME=ingestion

# ChromaDB base URL
CHROMA_URL=http://localhost:8000

# ChromaDB collection name (must match apps/web)
CHROMA_COLLECTION=secondseat_rag

# Embedding model — MUST match the model used in apps/inference
# Changing this breaks vector-space parity with the inference service
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2
EMBEDDING_DIMENSIONS=384

# Health check port
WORKERS_HEALTH_PORT=4100
