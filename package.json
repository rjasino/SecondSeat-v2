{
  "name": "secondseat",
  "version": "0.0.0",
  "private": true,
  "description": "SecondSeat — second-screen, spoiler-safe gaming companion (monorepo root).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@secondseat/web",
    "dev:inference": "npm run dev --workspace=@secondseat/inference",
    "dev:workers": "npm run dev --workspace=@secondseat/workers",
    "dev:seed": "npm run seed --workspace=@secondseat/web",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@vitejs/plugin-react": "^6.0.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.7",
    "@vitest/coverage-v8": "^4.1.7"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
