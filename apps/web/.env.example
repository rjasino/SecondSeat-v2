# apps/web — Next.js frontend
NODE_ENV=development
WEB_PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/secondseat

# Redis (BullMQ job queue)
REDIS_URL=redis://localhost:6379

# Session (iron-session) — must be ≥ 32 characters
SESSION_SECRET=change-me-to-a-random-32-char-secret!!

# Ingestion limits
INGEST_MAX_FILE_BYTES=5242880

# Seed accounts (run: tsx --env-file=.env packages/db/scripts/seed-admins.ts)
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=
SEED_AUTHOR_EMAIL=author@example.com
SEED_AUTHOR_PASSWORD=
