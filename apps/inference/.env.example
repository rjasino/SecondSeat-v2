# MongoDB
MONGODB_URI=mongodb://localhost:27017/secondseat

# ChromaDB
CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=secondseat_rag

# Service-to-service auth (Next.js → Express)
# Must match INFERENCE_SERVICE_SECRET in apps/web .env
INFERENCE_SERVICE_SECRET=change-me-in-production

# LLM provider: "anthropic" | "opencode_zen"
LLM_PROVIDER=opencode_zen

# Anthropic (production)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenCode Zen (development)
# Base URL must terminate at /v1 — the OpenAI SDK appends /responses internally.
OPENCODE_ZEN_BASE_URL=https://opencode.ai/zen/v1
OPENCODE_ZEN_API_KEY=
OPENCODE_ZEN_MODEL=opencode/claude-haiku-4-5

# Retrieval tuning
RETRIEVAL_K=4
# Minimum cosine similarity (0–1). Converts to max L2 distance internally.
RETRIEVAL_MIN_SCORE=0.3

# LLM call timeout in milliseconds
LLM_TIMEOUT_MS=30000

# Server port
PORT=3001
