{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node .claude/hooks/check-workflow-gate.cjs",
            "timeout": 5,
            "statusMessage": "Checking workflow gate..."
          }
        ]
      }
    ]
  }
}
