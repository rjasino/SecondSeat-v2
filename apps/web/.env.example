# MongoDB connection string
MONGO_URL=mongodb://localhost:27017/secondseat

# Redis connection string (for BullMQ)
REDIS_URL=redis://localhost:6379

# iron-session encryption key — must be at least 32 characters
SESSION_PASSWORD=change-me-to-a-long-random-secret-string-here

# Directory where uploaded files are stored (must exist and be writable)
INGEST_UPLOAD_DIR=/tmp/secondseat-uploads

# Max upload size in bytes (default 5 MB)
INGEST_MAX_FILE_BYTES=5242880

# BullMQ queue name (must match INGEST_QUEUE_NAME in apps/workers/.env)
INGEST_QUEUE_NAME=ingestion

# Max retry attempts for the delete-source BullMQ job (default 3)
DELETE_QUEUE_ATTEMPTS=3

# ChromaDB base URL
CHROMA_URL=http://localhost:8000

# ChromaDB collection name (must match workers)
CHROMA_COLLECTION=secondseat_rag

# Default game ID stamped on vectors for retrieval-time scoping
GAME_ID=default

# Inference service — must match apps/inference .env
INFERENCE_URL=http://localhost:3001
INFERENCE_SERVICE_SECRET=change-me-in-production

# --- Admin seeding (used by npm run seed:admin only) ---
SEED_ADMIN_EMAIL=admin@secondseat.local
SEED_ADMIN_PASSWORD=
SEED_ADMIN_NAME=Admin
