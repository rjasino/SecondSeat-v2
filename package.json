{
  "name": "secondseat",
  "version": "0.0.0",
  "private": true,
  "description": "SecondSeat — second-screen, spoiler-safe gaming companion (monorepo root).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@secondseat/web",
    "dev:inference": "npm run dev --workspace=@secondseat/inference",
    "dev:workers": "npm run dev --workspace=@secondseat/workers",
    "seed:default": "tsx --env-file=packages/db/.env packages/db/scripts/seed-admins.ts",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.5",
    "@vitest/coverage-v8": "^2.1.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
